{
  "name": "issue-pilot",
  "version": "1.0.0",
  "description": "AI-powered GitHub Issue triage - automatically label, deduplicate, and route issues",
  "author": "Issue Pilot Contributors",
  "license": "MIT",
  "homepage": "https://github.com/sunqiang/issue-pilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunqiang/issue-pilot.git"
  },
  "bugs": {
    "url": "https://github.com/sunqiang/issue-pilot/issues"
  },
  "keywords": [
    "github",
    "issues",
    "triage",
    "ai",
    "automation",
    "openai",
    "github-action",
    "labeling",
    "duplicate-detection",
    "gpt-4o",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "issue-pilot": "./dist/src/index.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "dev:action": "tsx action/index.ts",
    "lint": "eslint src/**/*.ts action/**/*.ts",
    "lint:fix": "eslint src/**/*.ts action/**/*.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "dotenv": "^16.4.5",
    "openai": "^4.56.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
