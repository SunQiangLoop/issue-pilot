# Issue Pilot Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key for AI-powered issue analysis (required)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token with repo scope (required)
# Create at: https://github.com/settings/tokens
# Required permissions: repo (for private repos) or public_repo (for public repos)
GITHUB_TOKEN=ghp_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Similarity threshold for duplicate detection (0.0 to 1.0)
# Higher values = stricter matching (fewer false positives)
# Default: 0.85
# DUPLICATE_THRESHOLD=0.85

# Automatically assign suggested team members to issues
# Default: false
# AUTO_ASSIGN=false

# Run in dry-run mode (analyze but don't apply changes)
# Default: false
# DRY_RUN=false
